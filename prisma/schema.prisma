generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  password          String
  role              UserRole       @default(USER)
  avatarUrl         String?
  isActive          Boolean        @default(true)
  favoriteTeamApiIds Int[]         @default([])
  favoriteCompetitionApiIds Int[]  @default([])
  passwordChangedAt DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  sessions          Session[]
  fetchJobs         FetchJob[]     @relation("FetchJobInitiator")
  activityLogs      ActivityLog[]
  mergeOperations   MergeOperation[]

  @@map("users")
}

model SiteSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  valueJson  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("site_settings")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

enum UserRole {
  ADMIN
  USER
  GUEST
}

model Season {
  id                 String              @id @default(cuid())
  year               Int                 @unique
  name               String
  startDate          DateTime
  endDate            DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  teams              Team[]
  games              Game[]
  standings          Standing[]
  competitions       CompetitionSeason[]
  playerStats        PlayerStatistics[]
  teamStats          TeamStatistics[]
  leaderboardEntries CompetitionLeaderboardEntry[]
  injuries           PlayerInjury[]
  transfers          PlayerTransfer[]
  trophies           PlayerTrophy[]
  predictions        GamePrediction[]
  headToHeadEntries  GameHeadToHeadEntry[]
  oddsValues         GameOddsValue[]
  predictionSnapshots GamePredictionSnapshot[]
  oddsSnapshots      GameOddsSnapshot[]
  liveSnapshots      LiveGameSnapshot[]
  sidelinedEntries   PlayerSidelinedEntry[]
  fetchJobs          FetchJob[]
  mediaAssets        MediaAsset[]
  coachAssignments   TeamCoachAssignment[]

  @@map("seasons")
}

model Competition {
  id             String              @id @default(cuid())
  apiFootballId  Int?                @unique
  countryEn      String?
  countryHe      String?
  nameEn         String
  nameHe         String
  logoUrl        String?
  type           CompetitionType     @default(LEAGUE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  seasons        CompetitionSeason[]
  games          Game[]
  standings      Standing[]
  playerStats    PlayerStatistics[]
  teamStats      TeamStatistics[]
  leaderboardEntries CompetitionLeaderboardEntry[]
  injuries       PlayerInjury[]
  predictions    GamePrediction[]
  headToHeadEntries GameHeadToHeadEntry[]
  oddsValues     GameOddsValue[]
  predictionSnapshots GamePredictionSnapshot[]
  oddsSnapshots  GameOddsSnapshot[]
  liveSnapshots  LiveGameSnapshot[]
  fetchJobs      FetchJob[]

  @@map("competitions")
}

enum CompetitionType {
  LEAGUE
  CUP
  EUROPE
}

model CompetitionSeason {
  id                  String     @id @default(cuid())
  competitionId       String
  seasonId            String
  stageNameEn         String?
  stageNameHe         String?
  currentRoundEn      String?
  currentRoundHe      String?
  standingsUpdatedAt  DateTime?
  fixturesUpdatedAt   DateTime?
  playersUpdatedAt    DateTime?
  additionalInfo      Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  competition         Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  season              Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([competitionId, seasonId])
  @@index([seasonId])
  @@map("competition_seasons")
}

model Team {
  id              String           @id @default(cuid())
  apiFootballId   Int?
  nameEn          String
  nameHe          String
  shortNameEn     String?
  shortNameHe     String?
  code            String?
  logoUrl         String?
  coach           String?
  coachHe         String?
  founded         Int?
  countryEn       String?
  countryHe       String?
  cityEn          String?
  cityHe          String?
  stadiumEn       String?
  stadiumHe       String?
  venueId         String?
  additionalInfo  Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  seasonId        String
  season          Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  venue           Venue?           @relation("TeamVenue", fields: [venueId], references: [id], onDelete: SetNull)
  players         Player[]
  homeGames       Game[]           @relation("HomeTeam")
  awayGames       Game[]           @relation("AwayTeam")
  standings       Standing[]
  teamStats       TeamStatistics[]
  lineupEntries   GameLineupEntry[]
  leaderboardEntries CompetitionLeaderboardEntry[]
  injuries        PlayerInjury[]
  fetchJobs       FetchJob[]
  homeEvents      GameEvent[]      @relation("EventTeam")
  uploads         MediaAsset[]     @relation("TeamAssets")
  coachAssignments TeamCoachAssignment[]

  @@unique([nameEn, seasonId])
  @@unique([apiFootballId, seasonId])
  @@index([seasonId])
  @@map("teams")
}

model Venue {
  id           String   @id @default(cuid())
  apiFootballId Int?    @unique
  nameEn       String
  nameHe       String
  addressEn    String?
  addressHe    String?
  cityEn       String?
  cityHe       String?
  countryEn    String?
  countryHe    String?
  capacity     Int?
  surface      String?
  imageUrl     String?
  additionalInfo Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  teams        Team[]   @relation("TeamVenue")
  games        Game[]   @relation("GameVenue")
  uploads      MediaAsset[] @relation("VenueAssets")

  @@index([nameEn])
  @@index([cityEn])
  @@map("venues")
}

model Referee {
  id         String   @id @default(cuid())
  nameEn     String   @unique
  nameHe     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  games      Game[]

  @@index([nameEn])
  @@map("referees")
}

model TeamCoachAssignment {
  id               String   @id @default(cuid())
  apiFootballCoachId Int?
  coachNameEn      String
  coachNameHe      String?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  teamId           String
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seasonId         String
  season           Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([teamId, seasonId, startDate])
  @@index([seasonId, coachNameEn])
  @@unique([teamId, seasonId, coachNameEn, startDate])
  @@map("team_coach_assignments")
}

model Player {
  id                String              @id @default(cuid())
  canonicalPlayerId String?
  apiFootballId     Int?
  nameEn            String
  nameHe            String
  firstNameEn       String?
  firstNameHe       String?
  lastNameEn        String?
  lastNameHe        String?
  jerseyNumber      Int?
  photoUrl          String?
  position          String?
  nationalityEn     String?
  nationalityHe     String?
  birthDate         DateTime?
  birthPlaceEn      String?
  birthPlaceHe      String?
  birthCountryEn    String?
  birthCountryHe    String?
  age               Int?
  height            String?
  weight            String?
  isInjured         Boolean?
  additionalInfo    Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  canonicalPlayer   Player?             @relation("CanonicalPlayer", fields: [canonicalPlayerId], references: [id], onDelete: SetNull)
  seasonEntries     Player[]            @relation("CanonicalPlayer")
  events            GameEvent[]         @relation("PrimaryPlayer")
  relatedEvents     GameEvent[]         @relation("RelatedPlayer")
  playerStats       PlayerStatistics[]
  lineupEntries     GameLineupEntry[]
  leaderboardEntries CompetitionLeaderboardEntry[]
  injuries          PlayerInjury[]
  transfers         PlayerTransfer[]
  trophies          PlayerTrophy[]
  sidelinedEntries  PlayerSidelinedEntry[]
  uploads           MediaAsset[]        @relation("PlayerAssets")

  @@unique([jerseyNumber, teamId])
  @@unique([apiFootballId, teamId])
  @@index([canonicalPlayerId])
  @@index([teamId])
  @@map("players")
}

model Game {
  id                  String            @id @default(cuid())
  apiFootballId       Int?              @unique
  externalRef         String?
  roundNameEn         String?
  roundNameHe         String?
  venueNameEn         String?
  venueNameHe         String?
  refereeEn           String?
  refereeHe           String?
  dateTime            DateTime
  timestamp           Int?
  timezone            String?
  statusShort         String?
  statusLong          String?
  elapsed             Int?
  extra               Int?
  homeScore           Int?
  awayScore           Int?
  homeScoreRegular    Int?              // תוצאת 90 דקות (כשיש הארכה)
  awayScoreRegular    Int?
  homePenalty         Int?
  awayPenalty         Int?
  status              GameStatus        @default(SCHEDULED)
  additionalInfo      Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  venueId             String?
  refereeId           String?
  homeTeamId          String
  homeTeam            Team              @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeamId          String
  awayTeam            Team              @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  seasonId            String
  season              Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId       String?
  competition         Competition?      @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  venue               Venue?            @relation("GameVenue", fields: [venueId], references: [id], onDelete: SetNull)
  referee             Referee?          @relation(fields: [refereeId], references: [id], onDelete: SetNull)
  events              GameEvent[]
  lineupEntries       GameLineupEntry[]
  gameStats           GameStatistics?
  injuries            PlayerInjury[]
  prediction          GamePrediction?
  predictionSnapshots GamePredictionSnapshot[]
  headToHeadEntries   GameHeadToHeadEntry[]
  oddsValues          GameOddsValue[]
  oddsSnapshots       GameOddsSnapshot[]
  liveSnapshots       LiveGameSnapshot[]
  fetchJobs           FetchJob[]
  activityLogs        ActivityLog[]

  @@index([seasonId, competitionId])
  @@map("games")
}

enum GameStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

model GameEvent {
  id               String         @id @default(cuid())
  apiFootballId    Int?
  minute           Int
  extraMinute      Int?
  type             EventType
  team             String
  notesEn          String?
  notesHe          String?
  icon             String?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  gameId           String
  game             Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId           String?
  eventTeam        Team?          @relation("EventTeam", fields: [teamId], references: [id], onDelete: SetNull)
  playerId              String?
  player                Player?        @relation("PrimaryPlayer", fields: [playerId], references: [id], onDelete: SetNull)
  participantName       String?
  relatedPlayerId       String?
  relatedPlayer         Player?        @relation("RelatedPlayer", fields: [relatedPlayerId], references: [id], onDelete: SetNull)
  relatedParticipantName String?
  assistPlayerId        String?

  @@index([gameId, sortOrder])
  @@map("game_events")
}

enum EventType {
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION_IN
  SUBSTITUTION_OUT
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISSED
  GOAL_DISALLOWED
}

model GameLineupEntry {
  id               String           @id @default(cuid())
  apiFootballId    Int?
  role             GameLineupRole
  participantType  LineupParticipantType @default(PLAYER)
  participantName  String?
  formation        String?
  positionName     String?
  positionGrid     String?
  jerseyNumber     Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  gameId           String
  game             Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId           String
  team             Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId         String?
  player           Player?          @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([gameId, teamId, role])
  @@unique([gameId, teamId, playerId, role, positionGrid])
  @@map("game_lineup_entries")
}

enum GameLineupRole {
  STARTER
  SUBSTITUTE
  COACH
}

enum LineupParticipantType {
  PLAYER
  COACH
}

model Standing {
  id              String       @id @default(cuid())
  position        Int
  played          Int          @default(0)
  wins            Int          @default(0)
  draws           Int          @default(0)
  losses          Int          @default(0)
  goalsFor        Int          @default(0)
  goalsAgainst    Int          @default(0)
  points          Int          @default(0)
  pointsAdjustment Int         @default(0)
  pointsAdjustmentNoteHe String?
  cleanSheets     Int          @default(0)
  form            String?
  goalsDiff       Int          @default(0)
  groupNameEn     String?
  groupNameHe     String?
  descriptionEn   String?
  descriptionHe   String?
  statusEn        String?
  statusHe        String?
  additionalInfo  Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  teamId          String
  team            Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seasonId        String
  season          Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId   String?
  competition     Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@unique([seasonId, teamId])
  @@index([competitionId, position])
  @@map("standings")
}

model PlayerStatistics {
  id              String       @id @default(cuid())
  goals           Int          @default(0)
  assists         Int          @default(0)
  yellowCards     Int          @default(0)
  redCards        Int          @default(0)
  gamesPlayed     Int          @default(0)
  minutesPlayed   Int          @default(0)
  starts          Int          @default(0)
  substituteAppearances Int    @default(0)
  timesSubbedOff  Int          @default(0)
  shots           Int          @default(0)
  keyPasses       Int          @default(0)
  seasonLabelEn   String?
  seasonLabelHe   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  playerId        String
  player          Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  seasonId        String?
  season          Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  competitionId   String?
  competition     Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@unique([playerId, seasonId, competitionId])
  @@index([playerId, seasonId])
  @@map("player_statistics")
}

model TeamStatistics {
  id                String       @id @default(cuid())
  matchesPlayed     Int          @default(0)
  totalGoals        Int          @default(0)
  totalAssists      Int          @default(0)
  goalsConceded     Int          @default(0)
  cleanSheets       Int          @default(0)
  yellowCards       Int          @default(0)
  redCards          Int          @default(0)
  shotsOnTarget     Int          @default(0)
  shotsTotal        Int          @default(0)
  corners           Int          @default(0)
  fouls             Int          @default(0)
  offsides          Int          @default(0)
  averagePossession Float        @default(0)
  wins              Int          @default(0)
  draws             Int          @default(0)
  losses            Int          @default(0)
  points            Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  teamId            String
  team              Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seasonId          String?
  season            Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  competitionId     String?
  competition       Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@unique([teamId, seasonId, competitionId])
  @@index([teamId, seasonId])
  @@map("team_statistics")
}

model CompetitionLeaderboardEntry {
  id                String                    @id @default(cuid())
  category          LeaderboardCategory
  rank              Int
  value             Int                       @default(0)
  gamesPlayed       Int                       @default(0)
  additionalInfo    Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  seasonId          String
  season            Season                    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId     String
  competition       Competition               @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  playerId          String?
  player            Player?                   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  apiFootballPlayerId Int?
  playerNameEn      String?
  playerNameHe      String?
  teamNameEn        String?
  teamNameHe        String?

  @@index([seasonId, competitionId, category, rank])
  @@unique([seasonId, competitionId, category, rank])
  @@map("competition_leaderboard_entries")
}

enum LeaderboardCategory {
  TOP_SCORERS
  TOP_ASSISTS
  TOP_YELLOW_CARDS
  TOP_RED_CARDS
  TOP_SUBSTITUTED_IN
  TOP_SUBSTITUTED_OUT
}

model GameStatistics {
  id                     String   @id @default(cuid())
  homeTeamPossession     Float?
  awayTeamPossession     Float?
  homeShotsOnTarget      Int?
  awayShotsOnTarget      Int?
  homeShotsTotal         Int?
  awayShotsTotal         Int?
  homeCorners            Int?
  awayCorners            Int?
  homeFouls              Int?
  awayFouls              Int?
  homeOffsides           Int?
  awayOffsides           Int?
  homeYellowCards        Int?
  awayYellowCards        Int?
  homeRedCards           Int?
  awayRedCards           Int?
  additionalInfo         Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  gameId                 String   @unique
  game                   Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_statistics")
}

model PlayerInjury {
  id                  String       @id @default(cuid())
  apiFootballPlayerId Int?
  apiFootballTeamId   Int?
  apiFootballFixtureId Int?
  playerNameEn        String?
  playerNameHe        String?
  teamNameEn          String?
  teamNameHe          String?
  typeEn              String?
  typeHe              String?
  reasonEn            String?
  reasonHe            String?
  fixtureDate         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  seasonId            String
  season              Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId       String?
  competition         Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  teamId              String?
  team                Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  playerId            String?
  player              Player?      @relation(fields: [playerId], references: [id], onDelete: SetNull)
  gameId              String?
  game                Game?        @relation(fields: [gameId], references: [id], onDelete: SetNull)

  @@index([seasonId, competitionId, teamId])
  @@index([apiFootballFixtureId, apiFootballPlayerId])
  @@map("player_injuries")
}

model PlayerTransfer {
  id                       String   @id @default(cuid())
  apiFootballPlayerId      Int?
  playerNameEn             String?
  playerNameHe             String?
  transferDate             DateTime?
  transferTypeEn           String?
  transferTypeHe           String?
  sourceTeamApiFootballId  Int?
  sourceTeamNameEn         String?
  sourceTeamNameHe         String?
  sourceTeamLogoUrl        String?
  destinationTeamApiFootballId Int?
  destinationTeamNameEn    String?
  destinationTeamNameHe    String?
  destinationTeamLogoUrl   String?
  sourceUpdatedAt          DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  seasonId                 String
  season                   Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  playerId                 String?
  player                   Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([seasonId, transferDate])
  @@index([apiFootballPlayerId, transferDate])
  @@map("player_transfers")
}

model PlayerTrophy {
  id                  String   @id @default(cuid())
  apiFootballPlayerId Int?
  playerNameEn        String?
  playerNameHe        String?
  leagueNameEn        String
  leagueNameHe        String?
  countryEn           String?
  countryHe           String?
  seasonLabel         String?
  placeEn             String?
  placeHe             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  seasonId            String
  season              Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  playerId            String?
  player              Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([seasonId, leagueNameEn])
  @@index([apiFootballPlayerId])
  @@map("player_trophies")
}

model GamePrediction {
  id                    String       @id @default(cuid())
  winnerTeamApiFootballId Int?
  winnerTeamNameEn      String?
  winnerTeamNameHe      String?
  winnerCommentEn       String?
  winnerCommentHe       String?
  adviceEn              String?
  adviceHe              String?
  winOrDraw             Boolean?
  underOver             String?
  goalsHome             String?
  goalsAway             String?
  percentHome           Int?
  percentDraw           Int?
  percentAway           Int?
  comparisonJson        Json?
  rawJson               Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  gameId                String       @unique
  game                  Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seasonId              String
  season                Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId         String?
  competition           Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@index([seasonId, competitionId])
  @@map("game_predictions")
}

model GamePredictionSnapshot {
  id                    String       @id @default(cuid())
  snapshotAt            DateTime     @default(now())
  winnerTeamApiFootballId Int?
  winnerTeamNameEn      String?
  winnerTeamNameHe      String?
  winnerCommentEn       String?
  winnerCommentHe       String?
  adviceEn              String?
  adviceHe              String?
  winOrDraw             Boolean?
  underOver             String?
  goalsHome             String?
  goalsAway             String?
  percentHome           Int?
  percentDraw           Int?
  percentAway           Int?
  comparisonJson        Json?
  rawJson               Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  gameId                String
  game                  Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seasonId              String
  season                Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId         String?
  competition           Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@index([gameId, snapshotAt])
  @@index([seasonId, competitionId, snapshotAt])
  @@map("game_prediction_snapshots")
}

model GameHeadToHeadEntry {
  id                         String       @id @default(cuid())
  apiFootballFixtureId       Int
  relatedCompetitionApiId    Int?
  relatedCompetitionNameEn   String?
  relatedCompetitionNameHe   String?
  relatedRoundEn             String?
  relatedRoundHe             String?
  relatedDate                DateTime?
  homeTeamApiFootballId      Int?
  homeTeamNameEn             String?
  homeTeamNameHe             String?
  awayTeamApiFootballId      Int?
  awayTeamNameEn             String?
  awayTeamNameHe             String?
  homeScore                  Int?
  awayScore                  Int?
  winnerTeamApiFootballId    Int?
  rawJson                    Json?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  gameId                     String
  game                       Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seasonId                   String
  season                     Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId              String?
  competition                Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@unique([gameId, apiFootballFixtureId])
  @@index([seasonId, competitionId, relatedDate])
  @@map("game_head_to_head_entries")
}

model GameOddsValue {
  id                    String       @id @default(cuid())
  bookmakerApiId        Int?
  bookmakerName         String
  marketApiId           Int?
  marketName            String
  selectionValue        String
  odd                   String
  oddsUpdatedAt         DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  bookmakerId           String?
  bookmaker             OddsBookmaker? @relation(fields: [bookmakerId], references: [id], onDelete: SetNull)
  betId                 String?
  bet                   OddsBet?     @relation(fields: [betId], references: [id], onDelete: SetNull)
  gameId                String
  game                  Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seasonId              String
  season                Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId         String?
  competition           Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@unique([gameId, bookmakerApiId, marketApiId, selectionValue])
  @@index([seasonId, competitionId, oddsUpdatedAt])
  @@map("game_odds_values")
}

model GameOddsSnapshot {
  id                    String       @id @default(cuid())
  snapshotAt            DateTime     @default(now())
  bookmakerApiId        Int?
  bookmakerName         String
  marketApiId           Int?
  marketName            String
  selectionValue        String
  odd                   String
  oddsUpdatedAt         DateTime?
  bookmakerId           String?
  bookmaker             OddsBookmaker? @relation(fields: [bookmakerId], references: [id], onDelete: SetNull)
  betId                 String?
  bet                   OddsBet?     @relation(fields: [betId], references: [id], onDelete: SetNull)
  gameId                String
  game                  Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seasonId              String
  season                Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competitionId         String?
  competition           Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([gameId, snapshotAt])
  @@index([seasonId, competitionId, snapshotAt])
  @@map("game_odds_snapshots")
}

model OddsBookmaker {
  id           String   @id @default(cuid())
  apiFootballId Int?    @unique
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  oddsValues   GameOddsValue[]
  oddsSnapshots GameOddsSnapshot[]

  @@index([name])
  @@map("odds_bookmakers")
}

model OddsBet {
  id           String   @id @default(cuid())
  apiFootballId Int?    @unique
  nameEn       String
  nameHe       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  oddsValues   GameOddsValue[]
  oddsSnapshots GameOddsSnapshot[]

  @@index([nameEn])
  @@map("odds_bets")
}

