generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String           @id @default(cuid())
  email                     String           @unique
  name                      String
  password                  String
  role                      UserRole         @default(USER)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  avatarUrl                 String?
  isActive                  Boolean          @default(true)
  passwordChangedAt         DateTime?
  favoriteCompetitionApiIds Int[]            @default([])
  favoriteTeamApiIds        Int[]            @default([])
  colorScheme               String           @default("auto")
  theme                     String           @default("modern")
  activityLogs              ActivityLog[]
  fetchJobs                 FetchJob[]       @relation("FetchJobInitiator")
  mergeOperations           MergeOperation[]
  sessions                  Session[]

  @@map("users")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Season {
  id                  String                        @id @default(cuid())
  year                Int                           @unique
  name                String
  startDate           DateTime
  endDate             DateTime
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  leaderboardEntries  CompetitionLeaderboardEntry[]
  competitions        CompetitionSeason[]
  fetchJobs           FetchJob[]
  headToHeadEntries   GameHeadToHeadEntry[]
  oddsSnapshots       GameOddsSnapshot[]
  oddsValues          GameOddsValue[]
  predictionSnapshots GamePredictionSnapshot[]
  predictions         GamePrediction[]
  games               Game[]
  liveSnapshots       LiveGameSnapshot[]
  mediaAssets         MediaAsset[]
  injuries            PlayerInjury[]
  sidelinedEntries    PlayerSidelinedEntry[]
  playerStats         PlayerStatistics[]
  transfers           PlayerTransfer[]
  trophies            PlayerTrophy[]
  standings           Standing[]
  coachAssignments    TeamCoachAssignment[]
  teamStats           TeamStatistics[]
  teams               Team[]

  @@map("seasons")
}

model Competition {
  id                  String                        @id @default(cuid())
  apiFootballId       Int?                          @unique
  countryEn           String?
  countryHe           String?
  nameEn              String
  nameHe              String
  logoUrl             String?
  type                CompetitionType               @default(LEAGUE)
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  leaderboardEntries  CompetitionLeaderboardEntry[]
  seasons             CompetitionSeason[]
  fetchJobs           FetchJob[]
  headToHeadEntries   GameHeadToHeadEntry[]
  oddsSnapshots       GameOddsSnapshot[]
  oddsValues          GameOddsValue[]
  predictionSnapshots GamePredictionSnapshot[]
  predictions         GamePrediction[]
  games               Game[]
  liveSnapshots       LiveGameSnapshot[]
  injuries            PlayerInjury[]
  playerStats         PlayerStatistics[]
  standings           Standing[]
  teamStats           TeamStatistics[]

  @@map("competitions")
}

model CompetitionSeason {
  id                 String      @id @default(cuid())
  competitionId      String
  seasonId           String
  stageNameEn        String?
  stageNameHe        String?
  currentRoundEn     String?
  currentRoundHe     String?
  standingsUpdatedAt DateTime?
  fixturesUpdatedAt  DateTime?
  playersUpdatedAt   DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  additionalInfo     Json?
  competition        Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  season             Season      @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([competitionId, seasonId])
  @@index([seasonId])
  @@map("competition_seasons")
}

model Team {
  id                 String                        @id @default(cuid())
  nameEn             String
  nameHe             String
  logoUrl            String?
  coach              String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  seasonId           String
  additionalInfo     Json?
  apiFootballId      Int?
  cityEn             String?
  cityHe             String?
  coachHe            String?
  code               String?
  countryEn          String?
  countryHe          String?
  founded            Int?
  shortNameEn        String?
  shortNameHe        String?
  stadiumEn          String?
  stadiumHe          String?
  venueId            String?
  leaderboardEntries CompetitionLeaderboardEntry[]
  fetchJobs          FetchJob[]
  homeEvents         GameEvent[]                   @relation("EventTeam")
  lineupEntries      GameLineupEntry[]
  awayGames          Game[]                        @relation("AwayTeam")
  homeGames          Game[]                        @relation("HomeTeam")
  uploads            MediaAsset[]                  @relation("TeamAssets")
  injuries           PlayerInjury[]
  players            Player[]
  standings          Standing[]
  coachAssignments   TeamCoachAssignment[]
  teamStats          TeamStatistics[]
  season             Season                        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  venue              Venue?                        @relation("TeamVenue", fields: [venueId], references: [id])

  @@unique([nameEn, seasonId])
  @@unique([apiFootballId, seasonId])
  @@index([seasonId])
  @@map("teams")
}

model Venue {
  id             String       @id @default(cuid())
  apiFootballId  Int?         @unique
  nameEn         String
  nameHe         String
  addressEn      String?
  addressHe      String?
  cityEn         String?
  cityHe         String?
  countryEn      String?
  countryHe      String?
  capacity       Int?
  surface        String?
  imageUrl       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  additionalInfo Json?
  games          Game[]       @relation("GameVenue")
  uploads        MediaAsset[] @relation("VenueAssets")
  teams          Team[]       @relation("TeamVenue")

  @@index([nameEn])
  @@index([cityEn])
  @@map("venues")
}

model Referee {
  id        String   @id @default(cuid())
  nameEn    String   @unique
  nameHe    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  games     Game[]

  @@index([nameEn])
  @@map("referees")
}

model TeamCoachAssignment {
  id                 String    @id @default(cuid())
  apiFootballCoachId Int?
  coachNameEn        String
  coachNameHe        String?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  teamId             String
  seasonId           String
  season             Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team               Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, seasonId, coachNameEn, startDate])
  @@index([teamId, seasonId, startDate])
  @@index([seasonId, coachNameEn])
  @@map("team_coach_assignments")
}

model Player {
  id                 String                        @id @default(cuid())
  nameEn             String
  nameHe             String
  jerseyNumber       Int?
  photoUrl           String?
  position           String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  teamId             String
  additionalInfo     Json?
  apiFootballId      Int?
  birthDate          DateTime?
  firstNameEn        String?
  firstNameHe        String?
  lastNameEn         String?
  lastNameHe         String?
  nationalityEn      String?
  nationalityHe      String?
  canonicalPlayerId  String?
  age                Int?
  birthCountryEn     String?
  birthCountryHe     String?
  birthPlaceEn       String?
  birthPlaceHe       String?
  height             String?
  isInjured          Boolean?
  weight             String?
  leaderboardEntries CompetitionLeaderboardEntry[]
  events             GameEvent[]                   @relation("PrimaryPlayer")
  relatedEvents      GameEvent[]                   @relation("RelatedPlayer")
  lineupEntries      GameLineupEntry[]
  uploads            MediaAsset[]                  @relation("PlayerAssets")
  injuries           PlayerInjury[]
  sidelinedEntries   PlayerSidelinedEntry[]
  playerStats        PlayerStatistics[]
  transfers          PlayerTransfer[]
  trophies           PlayerTrophy[]
  canonicalPlayer    Player?                       @relation("CanonicalPlayer", fields: [canonicalPlayerId], references: [id])
  seasonEntries      Player[]                      @relation("CanonicalPlayer")
  team               Team                          @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([jerseyNumber, teamId])
  @@unique([apiFootballId, teamId])
  @@index([canonicalPlayerId])
  @@index([teamId])
  @@map("players")
}

model Game {
  id                  String                   @id @default(cuid())
  dateTime            DateTime
  homeScore           Int?
  awayScore           Int?
  status              GameStatus               @default(SCHEDULED)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  homeTeamId          String
  awayTeamId          String
  seasonId            String
  apiFootballId       Int?                     @unique
  competitionId       String?
  externalRef         String?
  refereeEn           String?
  refereeHe           String?
  roundNameEn         String?
  roundNameHe         String?
  venueNameEn         String?
  venueNameHe         String?
  refereeId           String?
  venueId             String?
  additionalInfo      Json?
  elapsed             Int?
  extra               Int?
  statusLong          String?
  statusShort         String?
  timestamp           Int?
  timezone            String?
  awayPenalty         Int?
  homePenalty         Int?
  awayScoreRegular    Int?
  homeScoreRegular    Int?
  activityLogs        ActivityLog[]
  fetchJobs           FetchJob[]
  events              GameEvent[]
  headToHeadEntries   GameHeadToHeadEntry[]
  lineupEntries       GameLineupEntry[]
  oddsSnapshots       GameOddsSnapshot[]
  oddsValues          GameOddsValue[]
  predictionSnapshots GamePredictionSnapshot[]
  prediction          GamePrediction?
  gameStats           GameStatistics?
  awayTeam            Team                     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  competition         Competition?             @relation(fields: [competitionId], references: [id])
  homeTeam            Team                     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  referee             Referee?                 @relation(fields: [refereeId], references: [id])
  season              Season                   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  venue               Venue?                   @relation("GameVenue", fields: [venueId], references: [id])
  liveSnapshots       LiveGameSnapshot[]
  injuries            PlayerInjury[]
  winnerOdds          WinnerOdds[]

  @@index([seasonId, competitionId])
  @@map("games")
}

model GameEvent {
  id                     String    @id @default(cuid())
  minute                 Int
  type                   EventType
  team                   String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  gameId                 String
  playerId               String?
  assistPlayerId         String?
  apiFootballId          Int?
  extraMinute            Int?
  icon                   String?
  notesEn                String?
  notesHe                String?
  relatedPlayerId        String?
  sortOrder              Int       @default(0)
  teamId                 String?
  participantName        String?
  relatedParticipantName String?
  game                   Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player                 Player?   @relation("PrimaryPlayer", fields: [playerId], references: [id])
  relatedPlayer          Player?   @relation("RelatedPlayer", fields: [relatedPlayerId], references: [id])
  eventTeam              Team?     @relation("EventTeam", fields: [teamId], references: [id])

  @@index([gameId, sortOrder])
  @@map("game_events")
}

model GameLineupEntry {
  id              String                @id @default(cuid())
  apiFootballId   Int?
  role            GameLineupRole
  participantType LineupParticipantType @default(PLAYER)
  participantName String?
  formation       String?
  positionName    String?
  positionGrid    String?
  jerseyNumber    Int?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  gameId          String
  teamId          String
  playerId        String?
  game            Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player          Player?               @relation(fields: [playerId], references: [id])
  team            Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([gameId, teamId, playerId, role, positionGrid])
  @@index([gameId, teamId, role])
  @@map("game_lineup_entries")
}

model Standing {
  id                     String       @id @default(cuid())
  position               Int
  played                 Int          @default(0)
  wins                   Int          @default(0)
  draws                  Int          @default(0)
  losses                 Int          @default(0)
  goalsFor               Int          @default(0)
  goalsAgainst           Int          @default(0)
  points                 Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  teamId                 String
  seasonId               String
  cleanSheets            Int          @default(0)
  competitionId          String?
  form                   String?
  pointsAdjustment       Int          @default(0)
  pointsAdjustmentNoteHe String?
  additionalInfo         Json?
  descriptionEn          String?
  descriptionHe          String?
  goalsDiff              Int          @default(0)
  groupNameEn            String?
  groupNameHe            String?
  statusEn               String?
  statusHe               String?
  competition            Competition? @relation(fields: [competitionId], references: [id])
  season                 Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team                   Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId])
  @@index([competitionId, position])
  @@map("standings")
}

model PlayerStatistics {
  id                    String       @id @default(cuid())
  goals                 Int          @default(0)
  assists               Int          @default(0)
  yellowCards           Int          @default(0)
  redCards              Int          @default(0)
  gamesPlayed           Int          @default(0)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  playerId              String
  competitionId         String?
  keyPasses             Int          @default(0)
  minutesPlayed         Int          @default(0)
  seasonId              String?
  seasonLabelEn         String?
  seasonLabelHe         String?
  shots                 Int          @default(0)
  starts                Int          @default(0)
  substituteAppearances Int          @default(0)
  timesSubbedOff        Int          @default(0)
  competition           Competition? @relation(fields: [competitionId], references: [id])
  player                Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season                Season?      @relation(fields: [seasonId], references: [id])

  @@unique([playerId, seasonId, competitionId])
  @@index([playerId, seasonId])
  @@map("player_statistics")
}

model TeamStatistics {
  id                String       @id @default(cuid())
  totalGoals        Int          @default(0)
  totalAssists      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  teamId            String
  cleanSheets       Int          @default(0)
  competitionId     String?
  draws             Int          @default(0)
  goalsConceded     Int          @default(0)
  losses            Int          @default(0)
  points            Int          @default(0)
  seasonId          String?
  wins              Int          @default(0)
  averagePossession Float        @default(0)
  corners           Int          @default(0)
  fouls             Int          @default(0)
  matchesPlayed     Int          @default(0)
  offsides          Int          @default(0)
  redCards          Int          @default(0)
  shotsOnTarget     Int          @default(0)
  shotsTotal        Int          @default(0)
  yellowCards       Int          @default(0)
  competition       Competition? @relation(fields: [competitionId], references: [id])
  season            Season?      @relation(fields: [seasonId], references: [id])
  team              Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, seasonId, competitionId])
  @@index([teamId, seasonId])
  @@map("team_statistics")
}

model CompetitionLeaderboardEntry {
  id                  String              @id @default(cuid())
  category            LeaderboardCategory
  rank                Int
  value               Int                 @default(0)
  gamesPlayed         Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  seasonId            String
  competitionId       String
  teamId              String?
  playerId            String?
  apiFootballPlayerId Int?
  playerNameEn        String?
  playerNameHe        String?
  teamNameEn          String?
  teamNameHe          String?
  additionalInfo      Json?
  competition         Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  player              Player?             @relation(fields: [playerId], references: [id])
  season              Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team                Team?               @relation(fields: [teamId], references: [id])

  @@unique([seasonId, competitionId, category, rank])
  @@index([seasonId, competitionId, category, rank])
  @@map("competition_leaderboard_entries")
}

model GameStatistics {
  id                 String   @id @default(cuid())
  homeTeamPossession Float?
  awayTeamPossession Float?
  homeShotsOnTarget  Int?
  awayShotsOnTarget  Int?
  homeCorners        Int?
  awayCorners        Int?
  homeFouls          Int?
  awayFouls          Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  gameId             String   @unique
  awayOffsides       Int?
  awayRedCards       Int?
  awayShotsTotal     Int?
  awayYellowCards    Int?
  homeOffsides       Int?
  homeRedCards       Int?
  homeShotsTotal     Int?
  homeYellowCards    Int?
  additionalInfo     Json?
  game               Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_statistics")
}

model PlayerInjury {
  id                   String       @id @default(cuid())
  apiFootballPlayerId  Int?
  apiFootballTeamId    Int?
  apiFootballFixtureId Int?
  playerNameEn         String?
  playerNameHe         String?
  teamNameEn           String?
  teamNameHe           String?
  typeEn               String?
  typeHe               String?
  reasonEn             String?
  reasonHe             String?
  fixtureDate          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  seasonId             String
  competitionId        String?
  teamId               String?
  playerId             String?
  gameId               String?
  competition          Competition? @relation(fields: [competitionId], references: [id])
  game                 Game?        @relation(fields: [gameId], references: [id])
  player               Player?      @relation(fields: [playerId], references: [id])
  season               Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team                 Team?        @relation(fields: [teamId], references: [id])

  @@index([seasonId, competitionId, teamId])
  @@index([apiFootballFixtureId, apiFootballPlayerId])
  @@map("player_injuries")
}

model PlayerTransfer {
  id                           String    @id @default(cuid())
  apiFootballPlayerId          Int?
  playerNameEn                 String?
  playerNameHe                 String?
  transferDate                 DateTime?
  transferTypeEn               String?
  transferTypeHe               String?
  sourceTeamApiFootballId      Int?
  sourceTeamNameEn             String?
  sourceTeamNameHe             String?
  sourceTeamLogoUrl            String?
  destinationTeamApiFootballId Int?
  destinationTeamNameEn        String?
  destinationTeamNameHe        String?
  destinationTeamLogoUrl       String?
  sourceUpdatedAt              DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  seasonId                     String
  playerId                     String?
  player                       Player?   @relation(fields: [playerId], references: [id])
  season                       Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId, transferDate])
  @@index([apiFootballPlayerId, transferDate])
  @@map("player_transfers")
}

model PlayerTrophy {
  id                  String   @id @default(cuid())
  apiFootballPlayerId Int?
  playerNameEn        String?
  playerNameHe        String?
  leagueNameEn        String
  leagueNameHe        String?
  countryEn           String?
  countryHe           String?
  seasonLabel         String?
  placeEn             String?
  placeHe             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  seasonId            String
  playerId            String?
  player              Player?  @relation(fields: [playerId], references: [id])
  season              Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId, leagueNameEn])
  @@index([apiFootballPlayerId])
  @@map("player_trophies")
}

model GamePrediction {
  id                      String       @id @default(cuid())
  winnerTeamApiFootballId Int?
  winnerTeamNameEn        String?
  winnerTeamNameHe        String?
  winnerCommentEn         String?
  winnerCommentHe         String?
  adviceEn                String?
  adviceHe                String?
  winOrDraw               Boolean?
  underOver               String?
  goalsHome               String?
  goalsAway               String?
  percentHome             Int?
  percentDraw             Int?
  percentAway             Int?
  comparisonJson          Json?
  rawJson                 Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  gameId                  String       @unique
  seasonId                String
  competitionId           String?
  competition             Competition? @relation(fields: [competitionId], references: [id])
  game                    Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season                  Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId, competitionId])
  @@map("game_predictions")
}

model GamePredictionSnapshot {
  id                      String       @id @default(cuid())
  snapshotAt              DateTime     @default(now())
  winnerTeamApiFootballId Int?
  winnerTeamNameEn        String?
  winnerTeamNameHe        String?
  winnerCommentEn         String?
  winnerCommentHe         String?
  adviceEn                String?
  adviceHe                String?
  winOrDraw               Boolean?
  underOver               String?
  goalsHome               String?
  goalsAway               String?
  percentHome             Int?
  percentDraw             Int?
  percentAway             Int?
  comparisonJson          Json?
  rawJson                 Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  gameId                  String
  seasonId                String
  competitionId           String?
  competition             Competition? @relation(fields: [competitionId], references: [id])
  game                    Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season                  Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([gameId, snapshotAt])
  @@index([seasonId, competitionId, snapshotAt])
  @@map("game_prediction_snapshots")
}

model GameHeadToHeadEntry {
  id                       String       @id @default(cuid())
  apiFootballFixtureId     Int
  relatedCompetitionApiId  Int?
  relatedCompetitionNameEn String?
  relatedCompetitionNameHe String?
  relatedRoundEn           String?
  relatedRoundHe           String?
  relatedDate              DateTime?
  homeTeamApiFootballId    Int?
  homeTeamNameEn           String?
  homeTeamNameHe           String?
  awayTeamApiFootballId    Int?
  awayTeamNameEn           String?
  awayTeamNameHe           String?
  homeScore                Int?
  awayScore                Int?
  winnerTeamApiFootballId  Int?
  rawJson                  Json?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  gameId                   String
  seasonId                 String
  competitionId            String?
  competition              Competition? @relation(fields: [competitionId], references: [id])
  game                     Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season                   Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([gameId, apiFootballFixtureId])
  @@index([seasonId, competitionId, relatedDate])
  @@map("game_head_to_head_entries")
}

model GameOddsValue {
  id             String         @id @default(cuid())
  bookmakerApiId Int?
  bookmakerName  String
  marketApiId    Int?
  marketName     String
  selectionValue String
  odd            String
  oddsUpdatedAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  gameId         String
  seasonId       String
  competitionId  String?
  betId          String?
  bookmakerId    String?
  bet            OddsBet?       @relation(fields: [betId], references: [id])
  bookmaker      OddsBookmaker? @relation(fields: [bookmakerId], references: [id])
  competition    Competition?   @relation(fields: [competitionId], references: [id])
  game           Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season         Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([gameId, bookmakerApiId, marketApiId, selectionValue])
  @@index([seasonId, competitionId, oddsUpdatedAt])
  @@map("game_odds_values")
}

model GameOddsSnapshot {
  id             String         @id @default(cuid())
  snapshotAt     DateTime       @default(now())
  bookmakerApiId Int?
  bookmakerName  String
  marketApiId    Int?
  marketName     String
  selectionValue String
  odd            String
  oddsUpdatedAt  DateTime?
  bookmakerId    String?
  betId          String?
  gameId         String
  seasonId       String
  competitionId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bet            OddsBet?       @relation(fields: [betId], references: [id])
  bookmaker      OddsBookmaker? @relation(fields: [bookmakerId], references: [id])
  competition    Competition?   @relation(fields: [competitionId], references: [id])
  game           Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season         Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([gameId, snapshotAt])
  @@index([seasonId, competitionId, snapshotAt])
  @@map("game_odds_snapshots")
}

model OddsBookmaker {
  id            String             @id @default(cuid())
  apiFootballId Int?               @unique
  name          String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  oddsSnapshots GameOddsSnapshot[]
  oddsValues    GameOddsValue[]

  @@index([name])
  @@map("odds_bookmakers")
}

model OddsBet {
  id            String             @id @default(cuid())
  apiFootballId Int?               @unique
  nameEn        String
  nameHe        String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  oddsSnapshots GameOddsSnapshot[]
  oddsValues    GameOddsValue[]

  @@index([nameEn])
  @@map("odds_bets")
}

model LiveGameSnapshot {
  id                    String       @id @default(cuid())
  apiFootballFixtureId  Int
  leagueApiFootballId   Int?
  leagueNameEn          String?
  leagueNameHe          String?
  roundEn               String?
  roundHe               String?
  statusShort           String?
  statusLong            String?
  elapsed               Int?
  extra                 Int?
  snapshotAt            DateTime     @default(now())
  fixtureDate           DateTime?
  homeTeamApiFootballId Int?
  homeTeamNameEn        String?
  homeTeamNameHe        String?
  awayTeamApiFootballId Int?
  awayTeamNameEn        String?
  awayTeamNameHe        String?
  homeScore             Int?
  awayScore             Int?
  eventCount            Int          @default(0)
  rawJson               Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  gameId                String?
  seasonId              String?
  competitionId         String?
  feedScope             String       @default("LOCAL")
  competition           Competition? @relation(fields: [competitionId], references: [id])
  game                  Game?        @relation(fields: [gameId], references: [id])
  season                Season?      @relation(fields: [seasonId], references: [id])

  @@unique([apiFootballFixtureId, feedScope])
  @@unique([gameId, feedScope])
  @@index([feedScope, snapshotAt])
  @@index([seasonId, competitionId, snapshotAt])
  @@map("live_game_snapshots")
}

model CountryCatalog {
  id        String   @id @default(cuid())
  nameEn    String   @unique
  nameHe    String?
  code      String?
  flagUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@map("country_catalog")
}

model PlayerSidelinedEntry {
  id                  String    @id @default(cuid())
  apiFootballPlayerId Int?
  playerNameEn        String?
  playerNameHe        String?
  typeEn              String
  typeHe              String?
  startDate           DateTime?
  endDate             DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  seasonId            String
  playerId            String?
  player              Player?   @relation(fields: [playerId], references: [id])
  season              Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, apiFootballPlayerId, typeEn, startDate])
  @@index([seasonId, startDate])
  @@map("player_sidelined_entries")
}

model ActivityLog {
  id         String             @id @default(cuid())
  entityType ActivityEntityType
  entityId   String
  actionHe   String
  details    Json?
  timestamp  DateTime           @default(now())
  userId     String?
  gameId     String?
  game       Game?              @relation(fields: [gameId], references: [id])
  user       User?              @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@map("activity_logs")
}

model FetchJob {
  id              String         @id @default(cuid())
  status          FetchJobStatus @default(PENDING)
  labelHe         String
  requestPayload  Json
  progressPercent Int            @default(0)
  stepsJson       Json
  resultJson      Json?
  errorMessage    String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  initiatedById   String?
  seasonId        String?
  competitionId   String?
  teamId          String?
  gameId          String?
  competition     Competition?   @relation(fields: [competitionId], references: [id])
  game            Game?          @relation(fields: [gameId], references: [id])
  initiatedBy     User?          @relation("FetchJobInitiator", fields: [initiatedById], references: [id])
  season          Season?        @relation(fields: [seasonId], references: [id])
  team            Team?          @relation(fields: [teamId], references: [id])

  @@index([status, createdAt])
  @@map("fetch_jobs")
}

model MediaAsset {
  id           String         @id @default(cuid())
  kind         MediaAssetKind
  title        String?
  originalName String?
  filePath     String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  teamId       String?
  playerId     String?
  displayOrder Int            @default(0)
  isPrimary    Boolean        @default(false)
  seasonId     String?
  venueId      String?
  player       Player?        @relation("PlayerAssets", fields: [playerId], references: [id])
  season       Season?        @relation(fields: [seasonId], references: [id])
  team         Team?          @relation("TeamAssets", fields: [teamId], references: [id])
  venue        Venue?         @relation("VenueAssets", fields: [venueId], references: [id])

  @@index([seasonId])
  @@index([venueId])
  @@map("media_assets")
}

model ScrapedTeam {
  id           String            @id @default(cuid())
  source       String
  sourceId     String
  nameHe       String
  nameEn       String?
  logoUrl      String?
  season       String?
  leagueNameHe String?
  scrapedAt    DateTime          @default(now())
  rawJson      Json?
  matchesAway  ScrapedMatch[]    @relation("ScrapedAwayTeam")
  matchesHome  ScrapedMatch[]    @relation("ScrapedHomeTeam")
  players      ScrapedPlayer[]
  standings    ScrapedStanding[]

  @@unique([source, sourceId, season])
  @@index([source, season])
  @@map("scraped_teams")
}

model ScrapedPlayer {
  id           String                @id @default(cuid())
  source       String
  sourceId     String
  nameHe       String
  nameEn       String?
  position     String?
  jerseyNumber Int?
  photoUrl     String?
  scrapedAt    DateTime              @default(now())
  rawJson      Json?
  teamId       String
  birthDate    String?
  nationality  String?
  seasonStats  ScrapedPlayerSeason[]
  team         ScrapedTeam           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([source, sourceId, teamId])
  @@index([source, nameHe])
  @@map("scraped_players")
}

model ScrapedPlayerSeason {
  id              String        @id @default(cuid())
  source          String
  season          String
  teamNameHe      String?
  appearances     Int           @default(0)
  starts          Int           @default(0)
  goals           Int           @default(0)
  assists         Int           @default(0)
  yellowCards     Int           @default(0)
  redCards        Int           @default(0)
  subsIn          Int           @default(0)
  subsOut         Int           @default(0)
  minutesPlayed   Int           @default(0)
  scrapedAt       DateTime      @default(now())
  playerId        String
  yellowCardsToto Int           @default(0)
  player          ScrapedPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([source, season, playerId])
  @@index([season])
  @@map("scraped_player_seasons")
}

model ScrapedMatch {
  id               String               @id @default(cuid())
  source           String
  sourceId         String?
  season           String
  leagueNameHe     String?
  round            String?
  dateStr          String?
  dateTime         DateTime?
  homeTeamName     String
  awayTeamName     String
  homeScore        Int?
  awayScore        Int?
  homePenalty      Int?
  awayPenalty      Int?
  status           String?
  venue            String?
  referee          String?
  scrapedAt        DateTime             @default(now())
  rawJson          Json?
  homeTeamId       String?
  awayTeamId       String?
  awayHalfScore    Int?
  coachAway        String?
  coachHome        String?
  framework        String?
  homeHalfScore    Int?
  refereeAssist1   String?
  refereeAssist2   String?
  refereeFourth    String?
  refereeMain      String?
  refereeVar1      String?
  refereeVar2      String?
  awayScoreRegular Int?
  homeScoreRegular Int?
  events           ScrapedMatchEvent[]
  lineups          ScrapedMatchLineup[]
  awayTeam         ScrapedTeam?         @relation("ScrapedAwayTeam", fields: [awayTeamId], references: [id])
  homeTeam         ScrapedTeam?         @relation("ScrapedHomeTeam", fields: [homeTeamId], references: [id])

  @@unique([source, sourceId])
  @@index([source, season])
  @@index([dateTime])
  @@map("scraped_matches")
}

model ScrapedMatchEvent {
  id                 String        @id @default(cuid())
  source             String
  matchSourceId      String
  minute             Int
  type               String
  playerName         String
  playerNumber       Int?
  secondPlayerName   String?
  secondPlayerNumber Int?
  teamSide           String?
  teamName           String?
  scrapedAt          DateTime      @default(now())
  matchId            String?
  match              ScrapedMatch? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([source, matchSourceId])
  @@map("scraped_match_events")
}

model ScrapedMatchLineup {
  id             String        @id @default(cuid())
  source         String
  matchSourceId  String
  teamSide       String
  role           String
  playerName     String
  playerSourceId String?
  playerNumber   Int?
  positionMarker String?
  scrapedAt      DateTime      @default(now())
  matchId        String?
  match          ScrapedMatch? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([source, matchSourceId])
  @@map("scraped_match_lineups")
}

model ScrapedStanding {
  id             String       @id @default(cuid())
  source         String
  season         String
  leagueNameHe   String?
  position       Int
  teamNameHe     String
  played         Int          @default(0)
  wins           Int          @default(0)
  draws          Int          @default(0)
  losses         Int          @default(0)
  goalsFor       Int          @default(0)
  goalsAgainst   Int          @default(0)
  goalDifference Int          @default(0)
  points         Int          @default(0)
  scrapedAt      DateTime     @default(now())
  teamId         String?
  team           ScrapedTeam? @relation(fields: [teamId], references: [id])

  @@unique([source, season, leagueNameHe, position])
  @@index([source, season])
  @@map("scraped_standings")
}

model ScrapeJob {
  id             String    @id @default(cuid())
  source         String
  targetType     String
