// ──────────────────────────────────────────────
// External Scrape Storage (raw data from sport5, football.org.il, etc.)
// Stored separately from main models until manually merged
// ──────────────────────────────────────────────

model ScrapedTeam {
  id              String          @id @default(cuid())
  source          String          // 'sport5' | 'footballOrgIl'
  sourceId        String          // FolderID for sport5, club_id for IFA
  nameHe          String
  nameEn          String?
  logoUrl         String?
  season          String?         // e.g. '2025/26', '2024/25'
  leagueNameHe    String?
  scrapedAt       DateTime        @default(now())
  rawJson         Json?
  players         ScrapedPlayer[]
  standings       ScrapedStanding[]
  matchesHome     ScrapedMatch[]  @relation("ScrapedHomeTeam")
  matchesAway     ScrapedMatch[]  @relation("ScrapedAwayTeam")

  @@unique([source, sourceId, season])
  @@index([source, season])
  @@map("scraped_teams")
}

model ScrapedPlayer {
  id              String          @id @default(cuid())
  source          String
  sourceId        String          // PlayerID for sport5, player_id for IFA
  nameHe          String
  nameEn          String?
  position        String?
  jerseyNumber    Int?
  photoUrl        String?
  birthDate       String?         // e.g. '05/1992' from IFA
  nationality     String?         // e.g. 'ישראל'
  scrapedAt       DateTime        @default(now())
  rawJson         Json?
  teamId          String
  team            ScrapedTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seasonStats     ScrapedPlayerSeason[]

  @@unique([source, sourceId, teamId])
  @@index([source, nameHe])
  @@map("scraped_players")
}

model ScrapedPlayerSeason {
  id              String          @id @default(cuid())
  source          String
  season          String          // '2024/25', '2023/24', etc.
  teamNameHe      String?
  appearances     Int             @default(0)
  starts          Int             @default(0)
  goals           Int             @default(0)
  assists         Int             @default(0)
  yellowCards     Int             @default(0)
  yellowCardsToto Int            @default(0)
  redCards        Int             @default(0)
  subsIn          Int             @default(0)
  subsOut         Int             @default(0)
  minutesPlayed   Int             @default(0)
  scrapedAt       DateTime        @default(now())
  playerId        String
  player          ScrapedPlayer   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([source, season, playerId])
  @@index([season])
  @@map("scraped_player_seasons")
}

model ScrapedMatch {
  id              String          @id @default(cuid())
  source          String
  sourceId        String?         // GameID from source
  season          String
  leagueNameHe    String?
  round           String?
  dateStr         String?         // original date string from source
  dateTime        DateTime?
  homeTeamName    String
  awayTeamName    String
  homeScore       Int?            // תוצאה סופית (כולל הארכה)
  awayScore       Int?
  homeScoreRegular Int?          // תוצאת 90 דקות (כשיש הארכה)
  awayScoreRegular Int?
  homePenalty     Int?
  awayPenalty     Int?
  status          String?         // 'completed', 'scheduled', etc.
  venue           String?
  referee         String?         // raw full string
  refereeMain     String?         // שופט ראשי
  refereeAssist1  String?         // עוזר שופט 1
  refereeAssist2  String?         // עוזר שופט 2
  refereeFourth   String?         // שופט רביעי
  refereeVar1     String?         // שופט רחבה 1 / VAR
  refereeVar2     String?         // שופט רחבה 2
  homeHalfScore   Int?
  awayHalfScore   Int?
  framework       String?         // 'league', 'state_cup', 'toto_cup'
  coachHome       String?
  coachAway       String?
  scrapedAt       DateTime        @default(now())
  rawJson         Json?
  homeTeamId      String?
  homeTeam        ScrapedTeam?    @relation("ScrapedHomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeamId      String?
  awayTeam        ScrapedTeam?    @relation("ScrapedAwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  events          ScrapedMatchEvent[]
  lineups         ScrapedMatchLineup[]

  @@unique([source, sourceId])
  @@index([source, season])
  @@index([dateTime])
  @@map("scraped_matches")
}

model ScrapedMatchEvent {
  id                 String        @id @default(cuid())
  source             String
  matchSourceId      String
  minute             Int
  type               String        // 'goal', 'yellow_card', 'red_card', 'sub', 'own_goal', 'penalty_goal'
  playerName         String
  playerNumber       Int?
  secondPlayerName   String?       // for subs: player coming in
  secondPlayerNumber Int?
  teamSide           String?       // 'home' | 'away'
  teamName           String?
  scrapedAt          DateTime      @default(now())
  matchId            String?
  match              ScrapedMatch? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([source, matchSourceId])
  @@map("scraped_match_events")
}

model ScrapedMatchLineup {
  id               String        @id @default(cuid())
  source           String
  matchSourceId    String
  teamSide         String        // 'home' | 'away'
  role             String        // 'starter', 'sub', 'bench'
  playerName       String
  playerSourceId   String?       // IFA player_id
  playerNumber     Int?
  positionMarker   String?       // 'GK', 'C'
  scrapedAt        DateTime      @default(now())
  matchId          String?
  match            ScrapedMatch? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([source, matchSourceId])
  @@map("scraped_match_lineups")
}

model ScrapedStanding {
  id              String          @id @default(cuid())
  source          String
  season          String
  leagueNameHe    String?
  position        Int
  teamNameHe      String
  played          Int             @default(0)
  wins            Int             @default(0)
  draws           Int             @default(0)
  losses          Int             @default(0)
  goalsFor        Int             @default(0)
  goalsAgainst    Int             @default(0)
  goalDifference  Int             @default(0)
  points          Int             @default(0)
  scrapedAt       DateTime        @default(now())
  teamId          String?
  team            ScrapedTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([source, season, leagueNameHe, position])
  @@index([source, season])
  @@map("scraped_standings")
}

model ScrapeJob {
  id              String          @id @default(cuid())
  source          String
  targetType      String          // 'team', 'player', 'league', 'all'
  targetId        String?
  season          String?
  status          String          @default("pending") // 'pending', 'running', 'completed', 'failed'
  teamsScraped    Int             @default(0)
  playersScraped  Int             @default(0)
  matchesScraped  Int             @default(0)
  errorsCount     Int             @default(0)
  log             Json?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime        @default(now())

  @@index([source, status])
  @@map("scrape_jobs")
}

model ScrapedLeaderboard {
  id              String          @id @default(cuid())
  source          String          // 'walla', 'sport5', etc.
  season          String          // '2000/2001', '2024/2025'
  leagueNameHe    String?         // 'ליגת העל'
  category        String          // 'goals', 'assists', 'yellowCards', 'redCards', 'substitutedOut', 'substitutedIn'
  rank            Int
  playerName      String
  teamName        String
  value           Float           @default(0)
  scrapedAt       DateTime        @default(now())

  @@unique([source, season, category, rank])
  @@index([source, season])
  @@map("scraped_leaderboards")
}

// ──────────────────────────────────────────────
// Merge Operations — tracks every merge with rollback capability
// ──────────────────────────────────────────────

model MergeOperation {
  id              String          @id @default(cuid())
  source          String          // 'sport5' | 'footballOrgIl'
  mergeType       String          // 'players', 'standings', 'all'
  status          String          @default("preview") // 'preview', 'approved', 'executed', 'rolled_back', 'failed'
  description     String?
  previewJson     Json?           // what will change (before execution)
  changesJson     Json?           // what was actually changed (after execution)
  snapshotJson    Json?           // original values before merge (for rollback)
  recordsMatched  Int             @default(0)
  recordsUpdated  Int             @default(0)
  recordsCreated  Int             @default(0)
  recordsSkipped  Int             @default(0)
  approvedAt      DateTime?
  executedAt      DateTime?
  rolledBackAt    DateTime?
  createdAt       DateTime        @default(now())
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("merge_operations")
}
