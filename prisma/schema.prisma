  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([source, status])
  @@map("scrape_jobs")
}

model ScrapedLeaderboard {
  id           String   @id @default(cuid())
  source       String
  season       String
  leagueNameHe String?
  category     String
  rank         Int
  playerName   String
  teamName     String
  value        Float    @default(0)
  scrapedAt    DateTime @default(now())

  @@unique([source, season, category, rank])
  @@index([source, season])
  @@map("scraped_leaderboards")
}

model MergeOperation {
  id             String    @id @default(cuid())
  source         String
  mergeType      String
  status         String    @default("preview")
  description    String?
  previewJson    Json?
  changesJson    Json?
  snapshotJson   Json?
  recordsMatched Int       @default(0)
  recordsUpdated Int       @default(0)
  recordsCreated Int       @default(0)
  recordsSkipped Int       @default(0)
  approvedAt     DateTime?
  executedAt     DateTime?
  rolledBackAt   DateTime?
  createdAt      DateTime  @default(now())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@map("merge_operations")
}

model WinnerOdds {
  id        String   @id @default(cuid())
  winnerId  Int
  matchDesc String
  league    String
  matchTime DateTime
  odds1     Float
  oddsX     Float
  odds2     Float
  pct1      Float
  pctX      Float
  pct2      Float
  margin    Float
  isLive    Boolean  @default(false)
  gameId    String?
  fetchedAt DateTime @default(now())
  game      Game?    @relation(fields: [gameId], references: [id])

  @@unique([winnerId, fetchedAt])
  @@index([matchTime])
  @@index([gameId])
  @@map("winner_odds")
}

enum UserRole {
  ADMIN
  USER
  GUEST
}

enum CompetitionType {
  LEAGUE
  CUP
  EUROPE
}

enum GameStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventType {
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION_IN
  SUBSTITUTION_OUT
  OWN_GOAL
  PENALTY_GOAL
  PENALTY_MISSED
}

enum GameLineupRole {
  STARTER
  SUBSTITUTE
  COACH
}

enum LineupParticipantType {
  PLAYER
  COACH
}

enum LeaderboardCategory {
  TOP_SCORERS
  TOP_ASSISTS
  TOP_YELLOW_CARDS
  TOP_RED_CARDS
  TOP_SUBSTITUTED_IN
  TOP_SUBSTITUTED_OUT
}

enum ActivityEntityType {
  GAME
  PLAYER
  TEAM
  FETCH_JOB
  COMPETITION
  USER
}

enum FetchJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MediaAssetKind {
  TEAM_LOGO
  PLAYER_PHOTO
  BANNER
  VENUE_PHOTO
